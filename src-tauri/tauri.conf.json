{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lufal Ordenes",
  "version": "0.1.1",
  "identifier": "mx.lufal.ordenes",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lufal Órdenes de Compra",
        "width": 1100,
        "height": 780,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcwQUU2QTkxRjlCOTNFOTAKUldTUVBybjVrV3F1Y05sclNwb2dEcCt5ajBWcmorVFYrRXhhcWRpMXExMFN3ejR2ZnJMUDVEQzkK",
      "endpoints": [
        "https://github.com/elfershus/lufal-auxiliar/releases/latest/download/latest.json"
      ]
    }
  }
}
