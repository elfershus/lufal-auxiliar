{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lufal Auxiliar Desktop",
  "version": "0.1.5",
  "identifier": "mx.lufal.auxiliar.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lufal Auxiliar",
        "width": 1100,
        "height": 780,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFCNjE3MzA0NDNBRTY5RDkKUldUWmFhNURCSE5oR3dWYkhxMUxCaVFqczJGTC9MVWZnc3FkOTM1czRHcWNKb2J5aGo2amJwbGsK",
      "endpoints": [
        "https://central.pinturaslufal.com/updates/latest.json"
      ],
      "dialog": false
    }
  }
}
